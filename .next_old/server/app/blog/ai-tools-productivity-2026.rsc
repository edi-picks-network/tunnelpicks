1d:["$","p","36",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Motion uses AI to automatically schedule your work, prioritizing tasks based on deadlines and dependencies. It learns your working patterns and optimizes daily schedules. Users report saving 2-3 hours per week on calendar management alone. Price: $34/user/month for Team tier."]}]
