5b:["$","p","130",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["",["$","strong","1",{"className":"font-bold text-[#F0F4F8]","children":"Choose Gainsight if:"}]," You're an enterprise with a large CS team and need the most comprehensive CS platform available."]}]
