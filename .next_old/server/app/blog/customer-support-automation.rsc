1c:["$","p","28",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Help Scout focuses on simplicity and customer-centric support. Its shared inbox is intuitive, and its Docs knowledge base is beautifully designed. Help Scout avoids complex automation in favor of tools that help agents provide human, personal support. Beacon (in-app messaging) keeps conversations in context."]}]
1d:["$","p","30",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Pricing: $25/user/month for Standard, $40/user/month for Plus."]}]
