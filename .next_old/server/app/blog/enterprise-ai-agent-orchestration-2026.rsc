1b:["$","tr","4",{"className":"border-b border-[#1E3A5F]/50 hover:bg-[#162440]/50 transition-colors","children":[["$","td","0",{"className":"px-4 py-3 text-[#8BA3BE]","children":"Google Vertex AI Agent Builder"}],["$","td","1",{"className":"px-4 py-3 text-[#8BA3BE]","children":"~12%"}],["$","td","2",{"className":"px-4 py-3 text-[#8BA3BE]","children":"Google Cloud users"}],["$","td","3",{"className":"px-4 py-3 text-[#8BA3BE]","children":"$$0.07/agent/hr"}],["$","td","4",{"className":"px-4 py-3 text-[#8BA3BE]","children":"Multi-modal agents"}]]}]
1c:["$","tr","5",{"className":"border-b border-[#1E3A5F]/50 hover:bg-[#162440]/50 transition-colors","children":[["$","td","0",{"className":"px-4 py-3 text-[#8BA3BE]","children":"AWS Bedrock Agents"}],["$","td","1",{"className":"px-4 py-3 text-[#8BA3BE]","children":"~10%"}],["$","td","2",{"className":"px-4 py-3 text-[#8BA3BE]","children":"AWS-native deployments"}],["$","td","3",{"className":"px-4 py-3 text-[#8BA3BE]","children":"$$0.10/agent/hr"}],["$","td","4",{"className":"px-4 py-3 text-[#8BA3BE]","children":"Enterprise compliance"}]]}]
