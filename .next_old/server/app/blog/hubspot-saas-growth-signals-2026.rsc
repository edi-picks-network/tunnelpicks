70:["$","tr","7",{"className":"border-b border-[#1E3A5F]/50 hover:bg-[#162440]/50 transition-colors","children":[["$","td","0",{"className":"px-4 py-3 text-[#8BA3BE]","children":"AI Agent Readiness"}],["$","td","1",{"className":"px-4 py-3 text-[#8BA3BE]","children":"Developing (Breeze integrations)"}],["$","td","2",{"className":"px-4 py-3 text-[#8BA3BE]","children":"Strong (Einstein + MuleSoft)"}],["$","td","3",{"className":"px-4 py-3 text-[#8BA3BE]","children":"Limited"}],["$","td","4",{"className":"px-4 py-3 text-[#8BA3BE]","children":"Limited"}]]}]
