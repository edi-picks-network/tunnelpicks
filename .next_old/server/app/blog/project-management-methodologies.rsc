18:["$","div",null,{"className":"prose-custom max-w-none","children":[["$","p","0",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Selecting a project management methodology is one of the most impactful decisions a team can make. The methodology dictates daily workflows, communication patterns, delivery cadence, and ultimately, how value reaches customers."]}],["$","p","2",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["According to the Project Management Institute (PMI), organizations that use proven project management practices waste 28x less money than those that don't. But with so many methodologies available, how do you choose?"]}],["$","h2","4",{"className":"text-xl md:text-2xl font-bold text-[#F0F4F8] mt-10 mb-4 tracking-tight","children":"Waterfall"}],["$","p","6",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["The Waterfall model is the traditional approach, where each phase must be completed before the next begins: Requirements → Design → Implementation → Testing → Deployment → Maintenance."]}],["$","h3","8",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Pros"}],["$","p","9",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Clear milestones and deliverables at each stage"]}],["$","p","10",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Comprehensive documentation from the outset"]}],["$","p","11",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Predictable timeline and budget estimates"]}],["$","p","12",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Works well for projects with fixed, well-understood scope"]}],["$","h3","14",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Cons"}],["$","p","15",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Inflexible — changing requirements mid-project is costly and disruptive"]}],["$","p","16",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Testing happens late, so issues are discovered close to delivery"]}],["$","p","17",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Working software isn't produced until late in the lifecycle"]}],["$","p","18",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Limited customer feedback during development"]}],["$","h3","20",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Best For"}],["$","p","21",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Construction, manufacturing, government projects, and any initiative with strict regulatory requirements where scope is fixed upfront. Also suitable for small projects with clear, unchanging requirements."]}],["$","h2","23",{"className":"text-xl md:text-2xl font-bold text-[#F0F4F8] mt-10 mb-4 tracking-tight","children":"Agile"}],["$","p","25",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Agile is an umbrella philosophy defined by the Agile Manifesto (2001) with four core values: individuals and interactions over processes and tools, working software over comprehensive documentation, customer collaboration over contract negotiation, and responding to change over following a plan."]}],["$","h3","27",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Pros"}],["$","p","28",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Rapid delivery of value through iterative cycles"]}],["$","p","29",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Adaptable to changing requirements"]}],"$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37","$L38","$L39","$L3a","$L3b","$L3c","$L3d","$L3e","$L3f","$L40","$L41","$L42","$L43"]}]
