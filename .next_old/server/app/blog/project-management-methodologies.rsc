27:["$","p","46",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Scrum is the most popular Agile framework. It structures work in fixed-length sprints (typically 1-4 weeks) with defined roles: Product Owner (manages backlog), Scrum Master (facilitates process), and Development Team (builds product)."]}]
28:["$","h3","48",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Key Ceremonies"}]
29:["$","p","49",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Sprint Planning: Decide what to build in the upcoming sprint"]}]
2a:["$","p","50",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Daily Standup: 15-minute synchronization meeting"]}]
2b:["$","p","51",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Sprint Review: Demonstrate completed work to stakeholders"]}]
2c:["$","p","52",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Sprint Retrospective: Reflect on the process and identify improvements"]}]
2d:["$","h3","54",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Scrum Tools"}]
2e:["$","p","55",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Jira Software is the most popular Scrum tool, offering sprint planning boards, backlog management, velocity tracking, burndown charts, and reporting. Asana and Monday.com also support Scrum with custom workflows."]}]
2f:["$","h3","57",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Pros"}]
30:["$","p","58",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Clear accountability with defined roles"]}]
31:["$","p","59",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Regular delivery of working software"]}]
32:["$","p","60",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Continuous improvement through retrospectives"]}]
33:["$","p","61",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Transparency with visible progress tracking"]}]
34:["$","h3","63",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Cons"}]
35:["$","p","64",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Can be rigid with its prescribed roles and ceremonies"]}]
36:["$","p","65",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Requires experienced Scrum Master to be effective"]}]
37:["$","p","66",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Daily standups can become status reporting rather than coordination"]}]
38:["$","p","67",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["- Fixed sprint lengths may not fit all types of work"]}]
39:["$","h2","69",{"className":"text-xl md:text-2xl font-bold text-[#F0F4F8] mt-10 mb-4 tracking-tight","children":"Kanban"}]
3a:["$","p","71",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Kanban, another Agile framework, focuses on visualizing work, limiting work-in-progress (WIP), and optimizing flow. Unlike Scrum, there are no fixed iterations — work is pulled through the system continuously."]}]
3b:["$","h3","73",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Kanban Tools"}]
3c:["$","p","74",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Trello and Monday.com are popular for Kanban, offering visual boards with columns for each workflow stage (To Do, In Progress, Review, Done)."]}]
3d:["$","h3","76",{"className":"text-lg font-bold text-[#F0F4F8] mt-8 mb-3","children":"Best For"}]
3e:["$","p","77",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Support teams, maintenance work, operations, and any environment where work arrives continuously rather than in planned batches."]}]
3f:["$","h2","79",{"className":"text-xl md:text-2xl font-bold text-[#F0F4F8] mt-10 mb-4 tracking-tight","children":"Hybrid Approaches"}]
40:["$","p","81",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Many successful organizations adopt hybrid methodologies. For example, use Scrum for product development sprint cycles, Kanban for ongoing support and maintenance work, and Waterfall for compliance-heavy modules. The key is understanding the strengths of each methodology and applying them where they fit best."]}]
41:["$","h2","83",{"className":"text-xl md:text-2xl font-bold text-[#F0F4F8] mt-10 mb-4 tracking-tight","children":"Making the Choice"}]
42:["$","p","85",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["Consider these factors: project complexity and uncertainty, team size and experience, customer availability for feedback, regulatory requirements, and organizational culture. Most teams start with Scrum because it provides structure while remaining adaptable. If your requirements change frequently, go Agile. If they are fixed and well-understood, Waterfall may be more efficient."]}]
43:["$","p","87",{"className":"text-[#8BA3BE] leading-relaxed mb-4 text-base","children":["The best methodology is the one your team will actually follow consistently."]}]
d:[["$","meta","0",{"charSet":"utf-8"}],["$","meta","1",{"name":"viewport","content":"width=device-width, initial-scale=1"}]]
